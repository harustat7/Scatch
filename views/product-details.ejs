<%- include('./partials/header') %>

<div class="w-full min-h-[90vh] px-6 md:px-10 py-12 max-w-7xl mx-auto">
    <!-- Back Link -->
    <a href="/shop" class="inline-flex items-center gap-1.5 text-sm font-bold text-zinc-500 hover:text-zinc-800 mb-8 transition-colors">
        <i class="ri-arrow-left-line"></i> Back to Shop
    </a>

    <div class="flex flex-col lg:flex-row gap-12 items-stretch mb-16">
        
        <!-- Left Column: Product Image Showcase -->
        <div class="w-full lg:w-[45%] rounded-3xl flex items-center justify-center p-12 min-h-[400px] lg:min-h-0 relative select-none" style="background-color: <%= product.bgcolor || '#f4f4f5' %>">
            <% if(product.discount > 0) { %>
                <span class="absolute top-6 left-6 bg-red-500 text-white text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider shadow-md z-10 animate-pulse">
                    Save ₹<%= product.discount %>
                </span>
            <% } %>
            
            <!-- Wishlist Toggle -->
            <% if (wishlistIds.includes(product._id.toString())) { %>
                <a href="/wishlist/toggle/<%= product._id %>" class="absolute top-6 right-6 w-11 h-11 rounded-full bg-white shadow-md flex items-center justify-center text-red-500 hover:scale-110 transition-transform z-20">
                    <i class="ri-heart-3-fill text-xl"></i>
                </a>
            <% } else { %>
                <a href="/wishlist/toggle/<%= product._id %>" class="absolute top-6 right-6 w-11 h-11 rounded-full bg-white shadow-md flex items-center justify-center text-zinc-400 hover:text-red-500 hover:scale-110 transition-transform z-20">
                    <i class="ri-heart-3-line text-xl"></i>
                </a>
            <% } %>

            <img src="data:image/png;base64,<%= product.image.toString('base64') %>" alt="<%= product.name %>" class="max-h-96 w-auto object-contain mix-blend-multiply hover:scale-[1.03] transition-transform duration-300">
        </div>

        <!-- Right Column: Product Purchasing Details -->
        <div class="w-full lg:w-[55%] flex flex-col justify-between py-2 space-y-8">
            
            <div class="space-y-4">
                <span class="inline-block bg-blue-50 text-blue-600 text-xs px-3 py-1 rounded-full font-bold uppercase tracking-wider">
                    <%= product.category %>
                </span>
                
                <h1 class="text-4xl font-extrabold text-zinc-800 tracking-tight leading-tight"><%= product.name %></h1>
                
                <!-- Ratings Summary -->
                <div class="flex items-center gap-2">
                    <div class="flex items-center text-amber-500 text-base">
                        <% for (let i = 1; i <= 5; i++) { %>
                            <% if (i <= Math.round(product.rating || 0)) { %>
                                <i class="ri-star-fill"></i>
                            <% } else { %>
                                <i class="ri-star-line text-zinc-300"></i>
                            <% } %>
                        <% } %>
                    </div>
                    <span class="text-sm font-bold text-zinc-700">
                        <%= (product.rating || 0).toFixed(1) %> / 5.0
                    </span>
                    <span class="text-xs font-semibold text-zinc-400">
                        (<%= product.reviews.length %> customer reviews)
                    </span>
                </div>

                <!-- Price Panel -->
                <div class="pt-2 flex items-center gap-3">
                    <% if (product.discount > 0) { %>
                        <span class="text-3xl font-black text-zinc-800">₹<%= product.price - product.discount %></span>
                        <span class="text-zinc-400 line-through text-lg font-bold">₹<%= product.price %></span>
                    <% } else { %>
                        <span class="text-3xl font-black text-zinc-800">₹<%= product.price %></span>
                    <% } %>
                </div>

                <div class="h-[1px] bg-zinc-100 my-4"></div>

                <!-- Description -->
                <div class="space-y-2">
                    <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400">Product Description</h3>
                    <p class="text-sm text-zinc-500 leading-relaxed"><%= product.description %></p>
                </div>
            </div>

            <!-- Options Panel -->
            <div class="space-y-6">
                <!-- Size Selectors -->
                <div>
                    <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">Select Size</h3>
                    <div class="flex gap-3" id="size-selector">
                        <% (product.sizes || ["S", "M", "L", "XL"]).forEach(function(size, index){ %>
                            <button type="button" onclick="selectSize(this)" class="w-10 h-10 rounded-full border border-zinc-200 hover:border-blue-500 hover:text-blue-600 text-sm font-bold text-zinc-600 flex items-center justify-center transition-all focus:outline-none size-btn <%= index === 1 ? 'border-blue-600 text-blue-600 ring-2 ring-blue-100' : '' %>">
                                <%= size %>
                            </button>
                        <% }) %>
                    </div>
                </div>

                <!-- Color Theme Selector -->
                <div>
                    <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">Color Theme</h3>
                    <div class="flex gap-3" id="color-selector">
                        <button type="button" onclick="selectColor(this)" class="w-8 h-8 rounded-full border border-zinc-200 focus:outline-none color-btn ring-2 ring-blue-500 ring-offset-2 scale-105" style="background-color: <%= product.bgcolor %>;"></button>
                        <button type="button" onclick="selectColor(this)" class="w-8 h-8 rounded-full border border-zinc-200 focus:outline-none color-btn" style="background-color: <%= product.panelcolor %>;"></button>
                        <button type="button" onclick="selectColor(this)" class="w-8 h-8 rounded-full border border-zinc-200 focus:outline-none color-btn" style="background-color: #fafafa;"></button>
                    </div>
                </div>

                <!-- Action Button -->
                <a href="/addtocart/<%= product._id %>" class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-2xl shadow-lg shadow-blue-500/10 hover:shadow-blue-500/20 transition-all text-base w-full sm:w-auto">
                    <i class="ri-shopping-cart-2-line text-lg"></i> Add to Shopping Cart
                </a>
            </div>

            <script>
                function selectSize(btn) {
                    document.querySelectorAll('.size-btn').forEach(b => {
                        b.classList.remove('border-blue-600', 'text-blue-600', 'ring-2', 'ring-blue-100');
                    });
                    btn.classList.add('border-blue-600', 'text-blue-600', 'ring-2', 'ring-blue-100');
                }

                function selectColor(btn) {
                    document.querySelectorAll('.color-btn').forEach(b => {
                        b.classList.remove('ring-2', 'ring-blue-500', 'ring-offset-2', 'scale-105');
                    });
                    btn.classList.add('ring-2', 'ring-blue-500', 'ring-offset-2', 'scale-105');
                }
            </script>

        </div>
    </div>

    <!-- Product Reviews Panel -->
    <div class="border-t border-zinc-100 pt-12">
        <h2 class="text-2xl font-extrabold text-zinc-800 mb-8 flex items-center gap-2">
            <i class="ri-discuss-line text-blue-600"></i> Customer Reviews
        </h2>

        <div class="grid lg:grid-cols-3 gap-10 items-start">
            
            <!-- Left Column: Add Review Form -->
            <div class="bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm space-y-6 lg:sticky lg:top-24">
                <h3 class="text-lg font-bold text-zinc-800">Submit your Review</h3>
                
                <form action="/products/review/<%= product._id %>" method="post" class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-2">Rating</label>
                        <select name="rating" class="w-full border border-zinc-200 rounded-xl px-3 py-3 outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm font-bold text-zinc-700 transition-all" required>
                            <option value="5">5 Stars (Excellent)</option>
                            <option value="4">4 Stars (Good)</option>
                            <option value="3">3 Stars (Average)</option>
                            <option value="2">2 Stars (Poor)</option>
                            <option value="1">1 Star (Terrible)</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-zinc-400 uppercase tracking-wider mb-2">Comments</label>
                        <textarea name="comment" rows="4" placeholder="Write your review here..." class="w-full border border-zinc-200 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 text-sm font-medium transition-all" required></textarea>
                    </div>

                    <button type="submit" class="w-full bg-zinc-900 hover:bg-zinc-800 text-white font-bold py-3 rounded-xl transition-all shadow-md">
                        Post Review
                    </button>
                </form>
            </div>

            <!-- Right Column: Reviews List -->
            <div class="lg:col-span-2 space-y-6">
                <% if (product.reviews.length === 0) { %>
                    <div class="p-8 text-center bg-zinc-50 rounded-3xl border border-dashed border-zinc-200">
                        <p class="text-sm font-bold text-zinc-400">No reviews yet for this product</p>
                        <p class="text-xs text-zinc-400 mt-1">Be the first to share your experience with other shoppers!</p>
                    </div>
                <% } else { %>
                    <div class="space-y-4 max-h-[500px] overflow-y-auto pr-2 divide-y divide-zinc-50">
                        <% product.reviews.forEach(function(review){ %>
                            <div class="pt-4 first:pt-0 space-y-2">
                                <div class="flex justify-between items-center">
                                    <h4 class="text-sm font-bold text-zinc-800"><%= review.username %></h4>
                                    <span class="text-xs text-zinc-400 font-semibold">
                                        <%= new Date(review.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                                    </span>
                                </div>
                                <div class="flex items-center text-amber-500 text-xs">
                                    <% for (let i = 1; i <= 5; i++) { %>
                                        <% if (i <= review.rating) { %>
                                            <i class="ri-star-fill"></i>
                                        <% } else { %>
                                            <i class="ri-star-line text-zinc-300"></i>
                                        <% } %>
                                    <% } %>
                                </div>
                                <p class="text-xs text-zinc-500 font-medium leading-relaxed"><%= review.comment %></p>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>

        </div>
    </div>
</div>

<%- include('./partials/footer') %>
