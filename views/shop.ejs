<%- include('./partials/header') %>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    .animate-float {
        animation: float 3s ease-in-out infinite;
    }
</style>

<div class="w-full min-h-[90vh] flex flex-col lg:flex-row px-6 md:px-10 py-10 gap-8">
    
    <!-- Sidebar Filters Form (combines all actions together) -->
    <form action="/shop" method="get" class="w-full lg:w-[22%] flex flex-col gap-6 bg-white p-6 rounded-3xl border border-zinc-100 h-fit shadow-sm">
        
        <!-- Text Search -->
        <div>
            <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">Search Products</h3>
            <div class="relative">
                <input name="search" type="text" placeholder="Search..." value="<%= query.search || '' %>" class="w-full border border-zinc-200 rounded-xl pl-10 pr-4 py-2.5 outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm font-medium">
                <i class="ri-search-line absolute left-3.5 top-1/2 -translate-y-1/2 text-zinc-400 text-sm"></i>
            </div>
        </div>

        <div class="h-[1px] bg-zinc-100"></div>

        <!-- Sort By -->
        <div>
            <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">Sort By</h3>
            <select class="w-full border border-zinc-200 rounded-xl px-3 py-2.5 outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm font-medium" name="sortby" onchange="this.form.submit()">
                <option value="newest" <%= (typeof query !== "undefined" && query.sortby === "newest") ? "selected" : "" %>>Newest First</option>
                <option value="price_lh" <%= (typeof query !== "undefined" && query.sortby === "price_lh") ? "selected" : "" %>>Price: Low to High</option>
                <option value="price_hl" <%= (typeof query !== "undefined" && query.sortby === "price_hl") ? "selected" : "" %>>Price: High to Low</option>
                <option value="rating" <%= (typeof query !== "undefined" && query.sortby === "rating") ? "selected" : "" %>>Top Customer Rated</option>
            </select>
        </div>

        <div class="h-[1px] bg-zinc-100"></div>

        <!-- Collections -->
        <div>
            <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">Collections</h3>
            <select class="w-full border border-zinc-200 rounded-xl px-3 py-2.5 outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm font-medium" name="filter" onchange="this.form.submit()">
                <option value="" <%= (typeof query === "undefined" || !query.filter) ? "selected" : "" %>>All Products</option>
                <option value="discount" <%= (typeof query !== "undefined" && query.filter === "discount") ? "selected" : "" %>>Discounted Only</option>
            </select>
        </div>

        <div class="h-[1px] bg-zinc-100"></div>

        <!-- Categories -->
        <div>
            <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">Category</h3>
            <select class="w-full border border-zinc-200 rounded-xl px-3 py-2.5 outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all text-sm font-medium" name="category" onchange="this.form.submit()">
                <option value="" <%= (typeof query === "undefined" || !query.category) ? "selected" : "" %>>All Categories</option>
                <% categories.forEach(function(cat){ %>
                    <option value="<%= cat %>" <%= (typeof query !== "undefined" && query.category === cat) ? "selected" : "" %>><%= cat %></option>
                <% }) %>
            </select>
        </div>

        <div class="h-[1px] bg-zinc-100"></div>

        <!-- Price Range -->
        <div>
            <h3 class="text-xs font-bold uppercase tracking-wider text-zinc-400 mb-3">Price Range</h3>
            <div class="flex gap-2 items-center">
                <input name="minPrice" type="number" placeholder="Min" value="<%= query.minPrice || '' %>" class="w-full border border-zinc-200 rounded-xl px-3 py-2 outline-none text-xs font-medium">
                <span class="text-zinc-300 text-xs font-bold">-</span>
                <input name="maxPrice" type="number" placeholder="Max" value="<%= query.maxPrice || '' %>" class="w-full border border-zinc-200 rounded-xl px-3 py-2 outline-none text-xs font-medium">
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="grid grid-cols-2 gap-3 pt-2">
            <a href="/shop" class="bg-zinc-100 hover:bg-zinc-200 text-zinc-700 text-xs font-bold py-2.5 rounded-xl transition-all text-center flex items-center justify-center gap-1">
                <i class="ri-refresh-line"></i> Clear
            </a>
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2.5 rounded-xl transition-all shadow-md">
                Apply Filters
            </button>
        </div>

        <div class="h-[1px] bg-zinc-100 mt-2"></div>
        
        <div class="text-[11px] font-bold text-zinc-400 uppercase tracking-wide">
            Total found: <%= products.length %> items
        </div>
    </form>

    <!-- Products Grid -->
    <div class="flex-grow flex flex-col gap-6">
        <% if (products.length === 0) { %>
            <div class="w-full flex flex-col items-center justify-center py-24 bg-white border border-zinc-100 rounded-3xl text-center shadow-sm">
                <div class="w-24 h-24 rounded-3xl bg-blue-50/50 flex items-center justify-center mb-6 text-blue-600 shadow-inner animate-float">
                    <i class="ri-search-eye-line text-5xl"></i>
                </div>
                <h3 class="text-xl font-bold text-zinc-700">No matching products</h3>
                <p class="text-zinc-400 mt-1 max-w-xs px-4">We couldn't find any products matching those filters. Try adjusting your search query or reset filters.</p>
                <a href="/shop" class="mt-6 inline-flex items-center gap-2 bg-blue-600 text-white text-xs font-bold px-5 py-2.5 rounded-xl shadow-md hover:bg-blue-700 hover:shadow-lg transition-all">
                    Reset Filters
                </a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 xl:grid-cols-3 gap-8">
                <% products.forEach(function(product){ %>
                    <div class="group bg-white border border-zinc-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col justify-between relative">
                        
                        <!-- Wishlist Toggle Icon -->
                        <% if (wishlistIds.includes(product._id.toString())) { %>
                            <a href="/wishlist/toggle/<%= product._id %>" class="absolute top-4 right-4 w-9 h-9 rounded-full bg-white shadow-md flex items-center justify-center text-red-500 hover:scale-110 transition-transform z-20" title="Remove from Wishlist">
                                <i class="ri-heart-3-fill text-lg"></i>
                            </a>
                        <% } else { %>
                            <a href="/wishlist/toggle/<%= product._id %>" class="absolute top-4 right-4 w-9 h-9 rounded-full bg-white shadow-md flex items-center justify-center text-zinc-400 hover:text-red-500 hover:scale-110 transition-transform z-20" title="Add to Wishlist">
                                <i class="ri-heart-3-line text-lg"></i>
                            </a>
                        <% } %>

                        <a href="/products/details/<%= product._id %>" class="block">
                            <!-- Product Image Panel with dynamic background color -->
                            <div class="w-full h-56 flex items-center justify-center p-6 relative" style="background-color: <%= product.bgcolor || '#f4f4f5' %>">
                                <% if(product.discount > 0) { %>
                                    <span class="absolute top-4 left-4 bg-red-500 text-white text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wider shadow-sm z-10">
                                        Save ₹<%= product.discount %>
                                    </span>
                                <% } %>
                                <img class="h-40 max-w-full object-contain mix-blend-multiply group-hover:scale-105 transition-transform duration-500" src="data:image/png;base64,<%= product.image.toString('base64') %>" alt="<%= product.name %>">
                            </div>

                            <!-- Product Info Panel with dynamic text and panel colors -->
                            <div class="p-5 flex flex-col gap-1.5" style="background-color: <%= product.panelcolor || '#ffffff' %>; color: <%= product.textcolor || '#18181b' %>">
                                <span class="text-[10px] font-bold uppercase tracking-wider opacity-60"><%= product.category %></span>
                                <h3 class="font-bold text-lg leading-tight tracking-tight line-clamp-1">
                                    <%= product.name %>
                                </h3>
                                <div class="flex items-center justify-between mt-1">
                                    <div class="flex items-center gap-2">
                                        <% if (product.discount > 0) { %>
                                            <span class="font-extrabold text-lg">₹<%= product.price - product.discount %></span>
                                            <span class="opacity-40 line-through text-xs font-medium">₹<%= product.price %></span>
                                        <% } else { %>
                                            <span class="font-extrabold text-lg">₹<%= product.price %></span>
                                        <% } %>
                                    </div>
                                    <% if (product.rating > 0) { %>
                                        <div class="flex items-center gap-1 text-xs font-bold text-amber-500">
                                            <i class="ri-star-fill"></i>
                                            <span><%= product.rating.toFixed(1) %></span>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </a>

                        <!-- Footer Cart Button -->
                        <div class="p-5 border-t border-zinc-50 flex items-center justify-between bg-zinc-50/50">
                            <span class="text-xs font-medium text-zinc-400">In Stock</span>
                            <a class="flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold px-4 py-2.5 rounded-xl transition-all shadow-md shadow-blue-500/10 hover:shadow-blue-500/20 group-hover:scale-[1.02]" href="/addtocart/<%= product._id %>">
                                <i class="ri-shopping-cart-2-line"></i> Add to Cart
                            </a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>

<%- include('./partials/footer') %>