<%- include('./partials/header') %>

<div class="w-full min-h-[90vh] flex flex-col md:flex-row px-10 py-10 gap-10">
    
    <!-- Sidebar Navigation -->
    <div class="w-full md:w-[20%] flex flex-col gap-6 bg-white p-6 rounded-2xl border border-zinc-100 h-fit shadow-sm">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-400">Admin Options</h3>
        <div class="flex flex-col gap-2 font-medium">
            <a href="/owners/products" class="block w-full py-2 px-3 rounded-lg bg-blue-50 text-blue-600 text-sm transition-colors">
                All Products
            </a>
            <a href="/owners/admin" class="block w-full py-2 px-3 rounded-lg hover:bg-zinc-50 text-zinc-600 text-sm transition-colors">
                Create New Product
            </a>
        </div>
    </div>

    <!-- Product Editing Panel -->
    <div class="flex-grow bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm max-w-4xl">
        <div class="mb-6">
            <h2 class="text-2xl font-bold text-zinc-800">Edit Product</h2>
            <p class="text-sm text-zinc-400 mt-1">Modify details for product ID: <span class="font-mono text-xs text-zinc-500 bg-zinc-50 px-2 py-1 rounded border border-zinc-100"><%= product._id %></span></p>
        </div>

        <form autocomplete="off" action="/owners/products/edit/<%= product._id %>" method="post" enctype="multipart/form-data" class="space-y-6">
            
            <!-- Details Card -->
            <div class="bg-zinc-50/50 border border-zinc-100 p-6 rounded-2xl space-y-4">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-400 mb-2">Product Information</h3>
                
                <div class="flex flex-col sm:flex-row gap-6 items-center">
                    <div class="w-24 h-24 rounded-2xl flex items-center justify-center shrink-0 border border-zinc-200 p-2 bg-white" style="background-color: <%= product.bgcolor %>">
                        <img src="data:image/png;base64,<%= product.image.toString('base64') %>" alt="<%= product.name %>" class="max-h-full max-w-full object-contain mix-blend-multiply">
                    </div>
                    <div class="flex-grow w-full">
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Product Image File (leave blank to keep current image)</label>
                        <input name="image" type="file" class="bg-white border border-zinc-200 p-2.5 rounded-xl w-full text-sm outline-none cursor-pointer focus:ring-2 focus:ring-blue-500/20">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Product Name</label>
                        <input name="name" type="text" placeholder="e.g. Clinge Bag" class="bg-white border border-zinc-200 p-3 rounded-xl w-full text-sm outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required value="<%= product.name %>">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Price (₹)</label>
                        <input name="price" type="number" placeholder="e.g. 1200" class="bg-white border border-zinc-200 p-3 rounded-xl w-full text-sm outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required value="<%= product.price %>">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Discount Price (₹)</label>
                        <input name="discount" type="number" placeholder="e.g. 200" class="bg-white border border-zinc-200 p-3 rounded-xl w-full text-sm outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" value="<%= product.discount || 0 %>">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Category</label>
                        <input name="category" type="text" placeholder="e.g. Accessories" class="bg-white border border-zinc-200 p-3 rounded-xl w-full text-sm outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required value="<%= product.category || 'General' %>">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Sizes (comma-separated)</label>
                        <input name="sizes" type="text" placeholder="e.g. S, M, L, XL" class="bg-white border border-zinc-200 p-3 rounded-xl w-full text-sm outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" value="<%= (product.sizes || []).join(', ') %>">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Product Description</label>
                    <textarea name="description" rows="3" placeholder="Describe the item material, design details..." class="bg-white border border-zinc-200 p-3 rounded-xl w-full text-sm outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" required><%= product.description %></textarea>
                </div>
            </div>

            <!-- Stylings Card -->
            <div class="bg-zinc-50/50 border border-zinc-100 p-6 rounded-2xl space-y-4">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-400 mb-2">Theme & Custom Colors</h3>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Background Color</label>
                        <input name="bgcolor" id="bgcolor-picker" type="color" value="<%= product.bgcolor || '#f4f4f5' %>" class="w-full h-12 rounded-xl cursor-pointer border border-zinc-200 p-1 bg-white outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Panel Color</label>
                        <input name="panelcolor" id="panelcolor-picker" type="color" value="<%= product.panelcolor || '#ffffff' %>" class="w-full h-12 rounded-xl cursor-pointer border border-zinc-200 p-1 bg-white outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Text Color</label>
                        <input name="textcolor" id="textcolor-picker" type="color" value="<%= product.textcolor || '#18181b' %>" class="w-full h-12 rounded-xl cursor-pointer border border-zinc-200 p-1 bg-white outline-none">
                    </div>
                </div>

                <div class="pt-2">
                    <label class="block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2">Preset Themes</label>
                    <div class="flex flex-wrap gap-2.5">
                        <button type="button" onclick="setTheme('#f4f4f5', '#ffffff', '#18181b')" class="text-xs px-3 py-1.5 rounded-full border border-zinc-200 hover:border-zinc-400 font-semibold transition-all">Default Light</button>
                        <button type="button" onclick="setTheme('#27272a', '#18181b', '#ffffff')" class="text-xs px-3 py-1.5 rounded-full border border-zinc-200 hover:border-zinc-400 font-semibold transition-all bg-zinc-800 text-white">Dark Elegance</button>
                        <button type="button" onclick="setTheme('#fef3c7', '#fffbeb', '#78350f')" class="text-xs px-3 py-1.5 rounded-full border border-zinc-200 hover:border-zinc-400 font-semibold transition-all bg-amber-50 text-amber-900">Sunset Amber</button>
                        <button type="button" onclick="setTheme('#d1fae5', '#f0fdf4', '#065f46')" class="text-xs px-3 py-1.5 rounded-full border border-zinc-200 hover:border-zinc-400 font-semibold transition-all bg-emerald-50 text-emerald-900">Forest Mint</button>
                        <button type="button" onclick="setTheme('#dbeafe', '#eff6ff', '#1e40af')" class="text-xs px-3 py-1.5 rounded-full border border-zinc-200 hover:border-zinc-400 font-semibold transition-all bg-blue-50 text-blue-900">Ocean Wave</button>
                    </div>
                </div>
            </div>

            <div class="flex justify-between items-center pt-4">
                <a href="/owners/products" class="bg-zinc-100 hover:bg-zinc-200 text-zinc-700 font-semibold px-6 py-3.5 rounded-xl transition-all text-sm">
                    Cancel
                </a>
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3.5 rounded-xl transition-all shadow-md shadow-blue-500/10 hover:shadow-lg">
                    Save Changes
                </button>
            </div>

        </form>
    </div>
</div>

<script>
    function setTheme(bg, panel, text) {
        document.getElementById('bgcolor-picker').value = bg;
        document.getElementById('panelcolor-picker').value = panel;
        document.getElementById('textcolor-picker').value = text;
    }
</script>

<%- include('./partials/footer') %>
