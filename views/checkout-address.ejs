<%- include('./partials/header') %>

<div class="w-full min-h-[90vh] px-10 py-12 max-w-7xl mx-auto">
    <!-- Progress Indicator -->
    <div class="mb-10 max-w-3xl mx-auto">
        <div class="flex items-center justify-between relative">
            <!-- Line Background -->
            <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-1 bg-zinc-200 -z-10 rounded-full"></div>
            <!-- Active Progress Line -->
            <div class="absolute left-0 top-1/2 -translate-y-1/2 h-1 bg-blue-600 -z-10 rounded-full transition-all duration-500" style="width: 25%;"></div>

            <!-- Step 1: Address -->
            <div class="flex flex-col items-center gap-2 bg-zinc-50 px-4">
                <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-sm shadow-md shadow-blue-500/20 ring-4 ring-blue-100">
                    1
                </div>
                <span class="text-xs font-bold text-blue-600 uppercase tracking-wider">Shipping</span>
            </div>

            <!-- Step 2: Payment -->
            <div class="flex flex-col items-center gap-2 bg-zinc-50 px-4">
                <div class="w-10 h-10 rounded-full bg-zinc-200 text-zinc-500 flex items-center justify-center font-bold text-sm">
                    2
                </div>
                <span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Payment & Coupon</span>
            </div>

            <!-- Step 3: Done -->
            <div class="flex flex-col items-center gap-2 bg-zinc-50 px-4">
                <div class="w-10 h-10 rounded-full bg-zinc-200 text-zinc-500 flex items-center justify-center font-bold text-sm">
                    3
                </div>
                <span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Confirmation</span>
            </div>
        </div>
    </div>

    <h2 class="text-3xl font-extrabold text-zinc-800 mb-8 flex items-center gap-2">
        <i class="ri-map-pin-line text-blue-600"></i> Shipping Information
    </h2>

    <div class="flex flex-col lg:flex-row gap-10 items-start">
        
        <!-- Left Side: Address Form -->
        <form action="/checkout/address" method="post" class="w-full lg:w-[65%] flex flex-col gap-8">
            
            <div class="bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm space-y-6">
                <h3 class="text-lg font-bold text-zinc-800 flex items-center gap-2">
                    <i class="ri-home-4-line text-blue-600"></i> Delivery Address
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Recipient Name</label>
                        <input name="fullname" type="text" placeholder="e.g. John Doe" minlength="3" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-medium" required value="<%= shippingAddress.fullname %>">
                    </div>
                    
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Street Address</label>
                        <input name="address" type="text" placeholder="e.g. 123 Luxury Avenue" minlength="5" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-medium" required value="<%= shippingAddress.address %>">
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">City</label>
                        <input name="city" type="text" placeholder="e.g. Mumbai" minlength="2" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-medium" required value="<%= shippingAddress.city %>">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">ZIP Code</label>
                            <input name="zip" type="text" placeholder="e.g. 400001" pattern="[0-9]{6}" maxlength="6" title="Please enter a 6-digit zip code" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-medium" required value="<%= shippingAddress.zip %>">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Country</label>
                            <input name="country" type="text" placeholder="e.g. India" minlength="2" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-medium" required value="<%= shippingAddress.country %>">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Proceed to Payment Button -->
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 rounded-2xl shadow-lg shadow-blue-500/10 hover:shadow-blue-500/20 transition-all flex items-center justify-center gap-2 text-base">
                Proceed to Payment <i class="ri-arrow-right-line text-lg"></i>
            </button>
        </form>

        <!-- Right Side: Order Summary Panel -->
        <div class="w-full lg:w-[35%] bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm lg:sticky lg:top-24 space-y-6">
            <h3 class="text-xl font-bold text-zinc-800">Review Items</h3>
            
            <!-- Items Scroll List -->
            <div class="space-y-4 max-h-[300px] overflow-y-auto pr-2 divide-y divide-zinc-50">
                <% user.cart.forEach(function(item){ %>
                    <div class="flex gap-4 items-center pt-4 first:pt-0">
                        <div class="w-14 h-14 rounded-xl flex items-center justify-center shrink-0" style="background-color: <%= item.bgcolor || '#f4f4f5' %>">
                            <img src="data:image/png;base64,<%= item.image.toString('base64') %>" alt="<%= item.name %>" class="h-10 w-10 object-contain mix-blend-multiply">
                        </div>
                        <div class="flex-grow min-w-0">
                            <h4 class="text-sm font-bold text-zinc-800 truncate"><%= item.name %></h4>
                            <span class="text-xs text-zinc-400 font-semibold">Qty: 1</span>
                        </div>
                        <span class="text-sm font-bold text-zinc-800">
                            ₹<%= item.price - (item.discount || 0) %>
                        </span>
                    </div>
                <% }) %>
            </div>

            <div class="h-[1px] bg-zinc-100"></div>

            <div class="space-y-4 text-sm font-medium text-zinc-500">
                <div class="flex justify-between">
                    <span>Original Price</span>
                    <span class="text-zinc-800">₹<%= totalMRP %></span>
                </div>
                <% if (totalDiscount > 0) { %>
                    <div class="flex justify-between">
                        <span>Savings</span>
                        <span class="text-emerald-600">- ₹<%= totalDiscount %></span>
                    </div>
                <% } %>
                <div class="flex justify-between">
                    <span>Platform Fee</span>
                    <span class="text-zinc-800">₹<%= platformFee %></span>
                </div>
                <div class="flex justify-between">
                    <span>Shipping</span>
                    <span class="text-emerald-600 font-bold">FREE</span>
                </div>
                
                <div class="border-t border-zinc-100 pt-4 mt-4">
                    <div class="flex justify-between items-end">
                        <span class="text-zinc-800 font-bold text-base">Grand Total</span>
                        <span class="text-2xl font-extrabold text-zinc-800">₹<%= bill %></span>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-2.5 justify-center text-xs text-zinc-400 font-semibold border-t border-zinc-50 pt-4">
                <i class="ri-shield-check-line text-lg text-emerald-500"></i> SSL Certified Encrypted Gateway
            </div>
        </div>

    </div>
</div>

<%- include('./partials/footer') %>
