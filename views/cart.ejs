<%- include('./partials/header') %>

<style>
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    .animate-float {
        animation: float 3s ease-in-out infinite;
    }
</style>

<div class="w-full min-h-[90vh] px-10 py-12 max-w-7xl mx-auto">
    <h2 class="text-3xl font-extrabold text-zinc-800 mb-8 flex items-center gap-2">
        <i class="ri-shopping-cart-2-line text-blue-600"></i> Your Shopping Cart
    </h2>

    <% if (user.cart.length === 0) { %>
        <div class="w-full flex flex-col items-center justify-center py-24 bg-white border border-zinc-100 rounded-3xl text-center shadow-sm">
            <div class="w-24 h-24 rounded-3xl bg-blue-50/50 text-blue-600 flex items-center justify-center mb-6 shadow-inner animate-float">
                <i class="ri-shopping-cart-2-line text-5xl"></i>
            </div>
            <h3 class="text-2xl font-bold text-zinc-700">Your cart is empty</h3>
            <p class="text-zinc-400 mt-2 max-w-sm px-4">Looks like you haven't added anything to your cart yet. Discover our premium collection today!</p>
            <a href="/shop" class="mt-8 inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3.5 rounded-xl transition-all shadow-md hover:shadow-lg">
                Continue Shopping <i class="ri-arrow-right-line"></i>
            </a>
        </div>
    <% } else { %>
        <div class="flex flex-col lg:flex-row gap-10 items-start">
            
            <!-- Left Side: Cart Items List -->
            <div class="w-full lg:w-[65%] flex flex-col gap-6">
                <% cartItems.forEach(function(cartItem){ %>
                    <% let item = cartItem.product; %>
                    <% let quantity = cartItem.quantity; %>
                    <div class="flex flex-col sm:flex-row bg-white border border-zinc-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                        
                        <!-- Thumbnail Image wrapper with product background color -->
                        <div class="w-full sm:w-48 h-48 flex items-center justify-center p-6 shrink-0 relative" style="background-color: <%= item.bgcolor || '#f4f4f5' %>">
                            <img src="data:image/png;base64,<%= item.image.toString('base64') %>" alt="<%= item.name %>" class="h-32 object-contain mix-blend-multiply hover:scale-105 transition-transform duration-300">
                        </div>

                        <!-- Content Panel -->
                        <div class="flex-grow p-6 flex flex-col justify-between" style="background-color: <%= item.panelcolor || '#ffffff' %>; color: <%= item.textcolor || '#18181b' %>">
                            <div>
                                <div class="flex justify-between items-start gap-4">
                                    <h3 class="text-xl font-bold tracking-tight line-clamp-1"><%= item.name %></h3>
                                    <a href="/cart/remove/<%= item._id %>" class="text-red-500 hover:text-red-700 hover:bg-red-50 w-8 h-8 rounded-full flex items-center justify-center transition-all border border-red-50 hover:border-red-100 shrink-0" title="Remove Item">
                                        <i class="ri-delete-bin-line"></i>
                                    </a>
                                </div>
                                <div class="flex items-center gap-2 mt-2">
                                    <% if (item.discount > 0) { %>
                                        <span class="font-bold text-lg">₹<%= item.price - item.discount %></span>
                                        <span class="text-zinc-400 line-through text-sm">₹<%= item.price %></span>
                                    <% } else { %>
                                        <span class="font-bold text-lg">₹<%= item.price %></span>
                                    <% } %>
                                </div>
                            </div>

                            <div class="flex items-center justify-between border-t border-zinc-100/50 pt-4 mt-4">
                                <div class="flex items-center gap-3">
                                    <span class="text-xs font-semibold uppercase tracking-wider text-zinc-400">Qty</span>
                                    <div class="flex items-center border border-zinc-200 rounded-lg overflow-hidden bg-zinc-50">
                                        <a href="/cart/decrement/<%= item._id %>" class="px-2 py-1 text-zinc-400 hover:bg-zinc-100 transition-colors"><i class="ri-subtract-line text-xs"></i></a>
                                        <span class="px-3 py-1 font-bold text-sm text-zinc-700"><%= quantity %></span>
                                        <a href="/cart/increment/<%= item._id %>" class="px-2 py-1 text-zinc-400 hover:bg-zinc-100 transition-colors"><i class="ri-add-line text-xs"></i></a>
                                    </div>
                                </div>
                                <span class="text-sm font-bold text-emerald-600">Free Delivery</span>
                            </div>
                        </div>

                    </div>
                <% }) %>
            </div>

            <!-- Right Side: Order Summary -->
            <div class="w-full lg:w-[35%] bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm lg:sticky lg:top-24">
                <h3 class="text-xl font-bold text-zinc-800 mb-6">Order Summary</h3>
                
                <div class="space-y-4 text-sm font-medium text-zinc-500">
                    <div class="flex justify-between">
                        <span>Price (<%= user.cart.length %> items)</span>
                        <span class="text-zinc-800">₹<%= totalMRP %></span>
                    </div>
                    <% if (totalDiscount > 0) { %>
                        <div class="flex justify-between">
                            <span>Discount</span>
                            <span class="text-emerald-600">- ₹<%= totalDiscount %></span>
                        </div>
                    <% } %>
                    <div class="flex justify-between">
                        <span>Platform Fee</span>
                        <span class="text-zinc-800">₹<%= platformFee %></span>
                    </div>
                    <div class="flex justify-between">
                        <span>Shipping Charges</span>
                        <span class="text-emerald-600 font-bold">FREE</span>
                    </div>
                    
                    <div class="border-t border-zinc-100 pt-4 mt-4">
                        <div class="flex justify-between items-end">
                            <span class="text-zinc-800 font-bold text-base">Total Amount</span>
                            <span class="text-2xl font-extrabold text-zinc-800">₹<%= bill %></span>
                        </div>
                    </div>
                </div>

                <a href="/checkout" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 rounded-2xl shadow-lg shadow-blue-500/10 hover:shadow-lg transition-all mt-8 flex items-center justify-center gap-2">
                    Proceed to Checkout <i class="ri-arrow-right-line"></i>
                </a>

                <div class="flex items-center gap-2.5 justify-center mt-6 text-xs text-zinc-400 font-semibold">
                    <i class="ri-secure-payment-line text-lg text-emerald-500"></i> Secure AES checkout powered by SSL
                </div>
            </div>

        </div>
    <% } %>
</div>

<%- include('./partials/footer') %>