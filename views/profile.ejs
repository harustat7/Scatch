<%- include('./partials/header') %>

<div class="w-full min-h-[90vh] px-6 md:px-10 py-12 max-w-7xl mx-auto">
    <h2 class="text-3xl font-extrabold text-zinc-800 mb-8 flex items-center gap-2">
        <i class="ri-user-settings-line text-blue-600"></i> My Account Profile
    </h2>

    <form action="/profile/update" method="post" enctype="multipart/form-data" class="flex flex-col lg:flex-row gap-10 items-stretch">
        
        <!-- Left Side: Profile Details -->
        <div class="w-full lg:w-[45%] bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm flex flex-col justify-between space-y-8">
            <div class="space-y-6">
                <div class="flex items-center gap-4">
                    <% if (user.picture) { %>
                        <img src="data:image/png;base64,<%= user.picture.toString('base64') %>" class="w-16 h-16 rounded-full object-cover border border-zinc-200 shadow-inner">
                    <% } else { %>
                        <div class="w-16 h-16 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center text-2xl font-black">
                            <%= user.fullname ? user.fullname.split(' ').map(n => n[0]).join('').toUpperCase() : 'U' %>
                        </div>
                    <% } %>
                    <div>
                        <h3 class="text-lg font-bold text-zinc-800"><%= user.fullname %></h3>
                        <p class="text-sm text-zinc-400 font-medium"><%= user.email %></p>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Change Profile Picture</label>
                    <input name="picture" type="file" accept="image/*" class="block w-full text-sm text-zinc-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 transition-colors">
                </div>

                <div class="h-[1px] bg-zinc-100"></div>

                <h4 class="text-base font-bold text-zinc-800 flex items-center gap-2">
                    <i class="ri-contacts-line text-blue-600"></i> Contact Information
                </h4>

                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Full Name</label>
                        <input name="fullname" type="text" placeholder="Your full name" minlength="3" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all text-sm font-medium" required value="<%= user.fullname || '' %>">
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Email Address</label>
                        <input type="email" class="bg-zinc-100 text-zinc-400 block w-full px-4 py-3 border border-zinc-200 rounded-xl text-sm font-medium cursor-not-allowed" disabled value="<%= user.email %>">
                        <span class="text-[10px] text-zinc-400 font-semibold mt-1 block">Email address cannot be changed.</span>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Contact Number</label>
                        <input name="contact" type="tel" placeholder="e.g. 9876543210" pattern="[0-9]{10}" maxlength="10" title="Please enter a valid 10-digit phone number" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all text-sm font-medium" value="<%= user.contact || '' %>">
                    </div>
                </div>
            </div>
            
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 rounded-xl shadow-lg shadow-blue-500/10 hover:shadow-blue-500/20 transition-all flex items-center justify-center gap-2 text-sm mt-6">
                <i class="ri-save-line text-base"></i> Save Changes
            </button>
        </div>

        <!-- Right Side: Default Shipping Address -->
        <div class="w-full lg:w-[55%] bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm space-y-6 flex flex-col justify-between">
            <div class="space-y-6">
                <h3 class="text-lg font-bold text-zinc-800 flex items-center gap-2">
                    <i class="ri-map-pin-user-line text-blue-600"></i> Default Shipping Address
                </h3>
                <p class="text-xs text-zinc-400 font-medium">Define your standard shipping details here. They will automatically auto-populate during checkout to save you time.</p>

                <% let addr = user.defaultAddress || {} %>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Recipient Name</label>
                        <input name="address_fullname" type="text" placeholder="e.g. John Doe" minlength="3" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all text-sm font-medium" value="<%= addr.fullname || '' %>">
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Street Address</label>
                        <input name="address" type="text" placeholder="e.g. 123 Luxury Avenue" minlength="5" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all text-sm font-medium" value="<%= addr.address || '' %>">
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">City</label>
                        <input name="city" type="text" placeholder="e.g. Mumbai" minlength="2" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all text-sm font-medium" value="<%= addr.city || '' %>">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">ZIP Code</label>
                            <input name="zip" type="text" placeholder="e.g. 400001" pattern="[0-9]{6}" maxlength="6" title="Please enter a 6-digit zip code" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all text-sm font-medium" value="<%= addr.zip || '' %>">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Country</label>
                            <input name="country" type="text" placeholder="e.g. India" minlength="2" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all text-sm font-medium" value="<%= addr.country || '' %>">
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="bg-blue-50 rounded-2xl p-4 text-xs text-blue-800 font-medium leading-relaxed flex items-start gap-2.5">
                <i class="ri-information-line text-lg text-blue-600 shrink-0 mt-0.5"></i>
                <div>
                    <strong>Pro Tip:</strong> Keeping your shipping address set prevents manual inputs during checkout. Just click proceed and pay!
                </div>
            </div>
        </div>

    </form>
</div>

<%- include('./partials/footer') %>
