<%- include('./partials/header', {loggedin: false}) %>

<% if(error.length > 0) { %>
    <div class="fixed top-5 left-1/2 -translate-x-1/2 z-50 p-4 rounded-xl bg-red-500 text-white shadow-lg flex items-center gap-3 animate-bounce">
        <i class="ri-error-warning-line text-xl"></i>
        <span class="font-medium"><%= error %></span>
    </div>
<% } %>

<div class="w-full min-h-[80vh] flex items-center justify-center px-10 py-12">
    <div class="max-w-md w-full bg-white rounded-3xl shadow-xl border border-zinc-100 p-10">
        <div class="text-center mb-8">
            <div class="w-12 h-12 rounded-2xl bg-indigo-50 flex items-center justify-center mx-auto mb-4">
                <i class="ri-shield-user-line text-2xl text-indigo-600"></i>
            </div>
            <h4 class="text-3xl font-extrabold text-zinc-800">Admin Control</h4>
            <p class="text-sm text-zinc-400 mt-2">Secure access for Scatch owners</p>
        </div>
        
        <div class="mb-6 p-4 bg-indigo-50 border border-indigo-100 rounded-2xl text-xs text-indigo-800 space-y-1">
            <p class="font-bold flex items-center gap-1.5"><i class="ri-information-line text-indigo-600 text-sm"></i> Default Admin Credentials:</p>
            <p><strong>Email:</strong> admin@scatch.com</p>
            <p><strong>Password:</strong> password123</p>
        </div>
        
        <form action="/owners/login" method="post" class="space-y-4">
            <div>
                <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Email Address</label>
                <input class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all"
                    type="email" placeholder="owner@scatch.com" name="email" required>
            </div>
            <div>
                <label class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Password</label>
                <input class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 outline-none block w-full px-4 py-3 border border-zinc-200 rounded-xl transition-all"
                    type="password" placeholder="••••••••" name="password" required>
            </div>
            
            <button type="submit" class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-all shadow-md shadow-indigo-500/10 hover:shadow-lg mt-4">
                Verify Credentials
            </button>
        </form>

        <div class="text-center mt-6">
            <a href="/" class="text-sm text-zinc-400 hover:text-zinc-600 transition-colors">
                <i class="ri-arrow-left-line"></i> Back to Main Store
            </a>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>