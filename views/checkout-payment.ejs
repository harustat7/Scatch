<%- include('./partials/header') %>

<style>
    .perspective-1000 {
        perspective: 1000px;
    }
    .transform-style-3d {
        transform-style: preserve-3d;
    }
    .backface-hidden {
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
    }
    .rotate-y-180 {
        transform: rotateY(180deg);
    }
    .flip-active {
        transform: rotateY(180deg);
    }
</style>

<div class="w-full min-h-[90vh] px-10 py-12 max-w-7xl mx-auto">
    <!-- Progress Indicator -->
    <div class="mb-10 max-w-3xl mx-auto">
        <div class="flex items-center justify-between relative">
            <!-- Line Background -->
            <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-1 bg-zinc-200 -z-10 rounded-full"></div>
            <!-- Active Progress Line -->
            <div class="absolute left-0 top-1/2 -translate-y-1/2 h-1 bg-blue-600 -z-10 rounded-full transition-all duration-500" style="width: 75%;"></div>

            <!-- Step 1: Address -->
            <a href="/checkout/address" class="flex flex-col items-center gap-2 bg-zinc-50 px-4 group">
                <div class="w-10 h-10 rounded-full bg-emerald-600 text-white flex items-center justify-center font-bold text-sm shadow-md shadow-emerald-500/20 group-hover:scale-105 transition-transform">
                    <i class="ri-check-line text-lg"></i>
                </div>
                <span class="text-xs font-bold text-emerald-600 uppercase tracking-wider">Shipping</span>
            </a>

            <!-- Step 2: Payment -->
            <div class="flex flex-col items-center gap-2 bg-zinc-50 px-4">
                <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-sm shadow-md shadow-blue-500/20 ring-4 ring-blue-100">
                    2
                </div>
                <span class="text-xs font-bold text-blue-600 uppercase tracking-wider">Payment & Coupon</span>
            </div>

            <!-- Step 3: Done -->
            <div class="flex flex-col items-center gap-2 bg-zinc-50 px-4">
                <div class="w-10 h-10 rounded-full bg-zinc-200 text-zinc-500 flex items-center justify-center font-bold text-sm">
                    3
                </div>
                <span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Confirmation</span>
            </div>
        </div>
    </div>

    <h2 class="text-3xl font-extrabold text-zinc-800 mb-8 flex items-center gap-2">
        <i class="ri-secure-payment-line text-blue-600"></i> Payment & Review
    </h2>

    <div class="flex flex-col lg:flex-row gap-10 items-start">
        
        <!-- Left Side: Shipping Address Summary, Coupons, and Payment Selection -->
        <div class="w-full lg:w-[65%] flex flex-col gap-8">
            
            <!-- Shipping Address Summary -->
            <div class="bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div class="space-y-2">
                    <h3 class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Deliver To</h3>
                    <p class="text-base font-bold text-zinc-800"><%= shippingAddress.fullname %></p>
                    <p class="text-sm font-medium text-zinc-500">
                        <%= shippingAddress.address %>, <%= shippingAddress.city %> - <%= shippingAddress.zip %>, <%= shippingAddress.country %>
                    </p>
                </div>
                <a href="/checkout/address" class="shrink-0 flex items-center gap-1.5 px-4 py-2 border border-zinc-200 hover:border-zinc-300 rounded-xl text-sm font-bold text-zinc-600 hover:bg-zinc-50 transition-all">
                    <i class="ri-edit-line"></i> Change Address
                </a>
            </div>

            <!-- Coupon Apply Section -->
            <div class="bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm space-y-6">
                <h3 class="text-lg font-bold text-zinc-800 flex items-center gap-2">
                    <i class="ri-coupon-3-line text-blue-600"></i> Apply Promo Coupon
                </h3>

                <% if (couponCode) { %>
                    <div class="flex items-center justify-between p-4 bg-emerald-50 border border-emerald-100 rounded-2xl">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-emerald-500 text-white flex items-center justify-center">
                                <i class="ri-coupon-line text-xl"></i>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-emerald-800">Coupon "<%= couponCode %>" Applied</p>
                                <p class="text-xs text-emerald-600 font-semibold">You saved ₹<%= totals.couponDiscount %> on this order!</p>
                            </div>
                        </div>
                        <form action="/checkout/remove-coupon" method="post">
                            <button type="submit" class="text-red-500 hover:text-red-700 font-bold text-xs uppercase tracking-wider bg-white border border-red-100 hover:border-red-200 px-3 py-1.5 rounded-xl transition-all">
                                Remove
                            </button>
                        </form>
                <% } else { %>
                    <form action="/checkout/apply-coupon" method="post" id="coupon-form" class="flex gap-3">
                        <input name="couponCode" id="coupon-input" type="text" placeholder="Enter Coupon Code (e.g. WELCOME20)" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-bold tracking-wide uppercase" required>
                        <button type="submit" class="bg-zinc-900 hover:bg-zinc-800 text-white font-bold px-6 py-3.5 rounded-xl transition-all text-sm shadow-md shrink-0">
                            Apply
                        </button>
                    </form>
 
                    <!-- Available Coupons List -->
                    <div class="space-y-2">
                        <p class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Available Offers (Click to apply):</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            <div onclick="applyCouponCode('WELCOME20')" class="p-3.5 border border-zinc-100 rounded-2xl flex items-center justify-between gap-4 bg-zinc-50/50 hover:bg-zinc-50 hover:border-blue-500 hover:shadow-sm cursor-pointer transition-all">
                                <div>
                                    <span class="inline-block bg-blue-50 text-blue-600 text-xs px-2 py-0.5 rounded-md font-bold mb-1">WELCOME20</span>
                                    <p class="text-xs text-zinc-500 font-semibold">Get 20% OFF on all products.</p>
                                </div>
                                <i class="ri-arrow-right-line text-zinc-400"></i>
                            </div>
                            <div onclick="applyCouponCode('SAVE10')" class="p-3.5 border border-zinc-100 rounded-2xl flex items-center justify-between gap-4 bg-zinc-50/50 hover:bg-zinc-50 hover:border-blue-500 hover:shadow-sm cursor-pointer transition-all">
                                <div>
                                    <span class="inline-block bg-blue-50 text-blue-600 text-xs px-2 py-0.5 rounded-md font-bold mb-1">SAVE10</span>
                                    <p class="text-xs text-zinc-500 font-semibold">Get 10% OFF on all products.</p>
                                </div>
                                <i class="ri-arrow-right-line text-zinc-400"></i>
                            </div>
                        </div>
                    </div>
                    <script>
                        function applyCouponCode(code) {
                            const input = document.getElementById('coupon-input');
                            if (input) {
                                input.value = code;
                                document.getElementById('coupon-form').submit();
                            }
                        }
                    </script>
                <% } %>
            </div>

            <!-- Payment Details Form -->
            <form action="/checkout/place-order" method="post" id="place-order-form" class="space-y-8">
                
                <div class="bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm space-y-6">
                    <h3 class="text-lg font-bold text-zinc-800 flex items-center gap-2">
                        <i class="ri-bank-card-line text-blue-600"></i> Select Payment Method
                    </h3>

                    <!-- Payment Options Radio/Cards Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- UPI -->
                        <label class="border-2 border-blue-600 bg-blue-50/20 rounded-2xl p-5 flex flex-col gap-3 cursor-pointer hover:bg-zinc-50/50 transition-all select-card" id="card-UPI">
                            <div class="flex justify-between items-center">
                                <span class="font-extrabold text-zinc-800 text-sm">UPI Payment</span>
                                <input type="radio" name="paymentMethod" value="UPI" checked class="w-4 h-4 text-blue-600 border-zinc-300 focus:ring-blue-500" onclick="selectPayment('UPI')">
                            </div>
                            <div class="flex items-center gap-2 text-zinc-400 text-2xl">
                                <i class="ri-phone-find-line"></i>
                                <span class="text-xs font-semibold text-zinc-400 uppercase tracking-wide">Instant Transfer</span>
                            </div>
                        </label>

                        <!-- Card -->
                        <label class="border-2 border-zinc-100 rounded-2xl p-5 flex flex-col gap-3 cursor-pointer hover:bg-zinc-50/50 transition-all select-card" id="card-Card">
                            <div class="flex justify-between items-center">
                                <span class="font-extrabold text-zinc-800 text-sm">Credit / Debit Card</span>
                                <input type="radio" name="paymentMethod" value="Card" class="w-4 h-4 text-blue-600 border-zinc-300 focus:ring-blue-500" onclick="selectPayment('Card')">
                            </div>
                            <div class="flex items-center gap-1.5 text-zinc-400 text-lg">
                                <i class="ri-visa-fill"></i>
                                <i class="ri-mastercard-fill"></i>
                                <i class="ri-bank-card-2-line"></i>
                            </div>
                        </label>

                        <!-- Cash -->
                        <label class="border-2 border-zinc-100 rounded-2xl p-5 flex flex-col gap-3 cursor-pointer hover:bg-zinc-50/50 transition-all select-card" id="card-Cash">
                            <div class="flex justify-between items-center">
                                <span class="font-extrabold text-zinc-800 text-sm">Cash on Delivery</span>
                                <input type="radio" name="paymentMethod" value="Cash" class="w-4 h-4 text-blue-600 border-zinc-300 focus:ring-blue-500" onclick="selectPayment('Cash')">
                            </div>
                            <div class="flex items-center gap-2 text-zinc-400 text-2xl">
                                <i class="ri-hand-coin-line"></i>
                                <span class="text-xs font-bold text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded">+ ₹50 fee</span>
                            </div>
                        </label>
                    </div>

                    <!-- Payment Inputs Container -->
                    <div class="mt-6 border-t border-zinc-50 pt-6">
                        
                        <!-- UPI Inputs -->
                        <div id="upi-fields" class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">UPI ID</label>
                                <div class="relative">
                                    <input name="upiId" id="input-upiId" type="text" placeholder="e.g. johndoe@okaxis" pattern="^[a-zA-Z0-9.\-_]{2,256}@[a-zA-Z]{2,64}$" title="Please enter a valid UPI ID (e.g. user@bank)" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full pl-12 pr-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-semibold tracking-wide" required>
                                    <i class="ri-qr-code-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 text-lg"></i>
                                </div>
                                <p class="text-[11px] text-zinc-400 mt-2 font-medium">A payment request will be sent to this UPI ID. Ensure it is correct.</p>
                            </div>
                        </div>

                        <!-- Card Inputs (Hidden by default) -->
                        <div id="card-fields" class="hidden space-y-4">
                            <!-- 3D Credit Card Mockup -->
                            <div class="w-full flex justify-center mb-6 perspective-1000">
                                <div id="credit-card-mockup" class="w-80 h-48 rounded-2xl relative transition-transform duration-500 transform-style-3d cursor-pointer shadow-xl text-white flex flex-col justify-between">
                                    
                                    <!-- Front Face -->
                                    <div class="absolute inset-0 w-full h-full p-6 flex flex-col justify-between backface-hidden rounded-2xl bg-gradient-to-br from-zinc-800 via-indigo-950 to-zinc-950">
                                        <div class="flex justify-between items-start">
                                            <div class="flex flex-col gap-1">
                                                <i class="ri-bank-card-line text-3xl opacity-75"></i>
                                                <div class="w-10 h-7 rounded bg-amber-400/80 opacity-90 relative overflow-hidden mt-1 shadow">
                                                    <!-- chip lines -->
                                                    <div class="absolute top-1/2 left-0 right-0 h-[1px] bg-zinc-700/30"></div>
                                                    <div class="absolute left-1/2 top-0 bottom-0 w-[1px] bg-zinc-700/30"></div>
                                                </div>
                                            </div>
                                            <span class="text-xs font-black tracking-widest uppercase italic opacity-75">VISA</span>
                                        </div>
                                        <div class="space-y-4">
                                            <div id="mock-number" class="text-lg font-bold tracking-widest text-center py-1 opacity-90 font-mono">
                                                •••• •••• •••• ••••
                                            </div>
                                            <div class="flex justify-between text-xs">
                                                <div class="flex flex-col min-w-0">
                                                    <span class="text-[9px] uppercase tracking-wider opacity-60">Card Holder</span>
                                                    <span id="mock-holder" class="font-bold tracking-wide truncate max-w-[180px]">FULL NAME</span>
                                                </div>
                                                <div class="flex flex-col items-end shrink-0">
                                                    <span class="text-[9px] uppercase tracking-wider opacity-60">Expires</span>
                                                    <span id="mock-expiry" class="font-bold">MM/YY</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Back Face -->
                                    <div class="absolute inset-0 w-full h-full flex flex-col justify-between backface-hidden rotate-y-180 rounded-2xl bg-gradient-to-br from-zinc-800 via-zinc-900 to-zinc-950">
                                        <div class="w-full h-10 bg-black mt-6"></div>
                                        <div class="px-6 pb-6">
                                            <div class="flex justify-between items-center bg-zinc-100 text-zinc-800 px-3 py-1.5 rounded font-mono text-right text-sm">
                                                <span class="text-[8px] text-zinc-400 uppercase font-sans tracking-wide">Signature</span>
                                                <span id="mock-cvv" class="font-black tracking-widest text-base">•••</span>
                                            </div>
                                            <div class="text-[9px] text-zinc-400 mt-4 leading-normal opacity-60">
                                                This card is security certified. Authorized signatures only.
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="md:col-span-2">
                                    <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Cardholder Name</label>
                                    <input name="cardholder" id="input-cardholder" type="text" placeholder="e.g. John Doe" minlength="3" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-semibold">
                                </div>

                                <div class="md:col-span-2 relative">
                                    <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Card Number</label>
                                    <div class="relative">
                                        <input name="cardnumber" id="input-cardnumber" type="text" placeholder="e.g. 1111222233334444" pattern="[0-9]{16}" maxlength="16" title="Please enter a 16-digit card number" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full pl-12 pr-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-semibold tracking-widest">
                                        <i class="ri-bank-card-line absolute left-4 top-1/2 -translate-y-1/2 text-zinc-400 text-lg"></i>
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">Expiration Date</label>
                                    <input name="expiry" id="input-expiry" type="text" placeholder="MM/YY" pattern="(0[1-9]|1[0-2])\/[0-9]{2}" maxlength="5" title="Please enter expiry date in MM/YY format" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-semibold">
                                </div>

                                <div>
                                    <label class="block text-xs font-bold text-zinc-500 uppercase tracking-wider mb-2">CVV / CVC Code</label>
                                    <input name="cvv" id="input-cvv" type="password" placeholder="•••" pattern="[0-9]{3}" maxlength="3" title="Please enter 3-digit CVV" class="bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none block w-full px-4 py-3.5 border border-zinc-200 rounded-xl transition-all text-sm font-semibold">
                                </div>
                            </div>
                        </div>

                        <!-- Cash Delivery details (Hidden by default) -->
                        <div id="cash-fields" class="hidden p-4 bg-amber-50 border border-amber-100 rounded-2xl flex items-center gap-3">
                            <i class="ri-information-line text-amber-600 text-xl"></i>
                            <div>
                                <p class="text-sm font-bold text-amber-800">Cash on Delivery selected</p>
                                <p class="text-xs text-amber-600 font-semibold">An additional ₹50 cash handling charge is applied. Pay only by cash at the time of delivery.</p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Complete Order Button for Form Submission -->
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 rounded-2xl shadow-lg shadow-blue-500/10 hover:shadow-blue-500/20 transition-all flex items-center justify-center gap-2 text-base">
                    <i class="ri-checkbox-circle-line text-lg"></i> Authorize & Place Order
                </button>
            </form>
        </div>

        <!-- Right Side: Order Summary Panel -->
        <div class="w-full lg:w-[35%] bg-white border border-zinc-100 rounded-3xl p-8 shadow-sm lg:sticky lg:top-24 space-y-6">
            <h3 class="text-xl font-bold text-zinc-800">Review Items</h3>
            
            <!-- Items Scroll List -->
            <div class="space-y-4 max-h-[300px] overflow-y-auto pr-2 divide-y divide-zinc-50">
                <% user.cart.forEach(function(item){ %>
                    <div class="flex gap-4 items-center pt-4 first:pt-0">
                        <div class="w-14 h-14 rounded-xl flex items-center justify-center shrink-0" style="background-color: <%= item.bgcolor || '#f4f4f5' %>">
                            <img src="data:image/png;base64,<%= item.image.toString('base64') %>" alt="<%= item.name %>" class="h-10 w-10 object-contain mix-blend-multiply">
                        </div>
                        <div class="flex-grow min-w-0">
                            <h4 class="text-sm font-bold text-zinc-800 truncate"><%= item.name %></h4>
                            <span class="text-xs text-zinc-400 font-semibold">Qty: 1</span>
                        </div>
                        <span class="text-sm font-bold text-zinc-800">
                            ₹<%= item.price - (item.discount || 0) %>
                        </span>
                    </div>
                <% }) %>
            </div>

            <div class="h-[1px] bg-zinc-100"></div>

            <div class="space-y-4 text-sm font-medium text-zinc-500">
                <div class="flex justify-between">
                    <span>Original Price</span>
                    <span class="text-zinc-800">₹<%= totals.totalMRP %></span>
                </div>
                <% if (totals.totalDiscount > 0) { %>
                    <div class="flex justify-between">
                        <span>Savings</span>
                        <span class="text-emerald-600">- ₹<%= totals.totalDiscount %></span>
                    </div>
                <% } %>
                <div class="flex justify-between">
                    <span>Platform Fee</span>
                    <span class="text-zinc-800">₹<%= totals.platformFee %></span>
                </div>
                
                <!-- Coupon row -->
                <div id="coupon-row" class="flex justify-between <%= totals.couponDiscount > 0 ? '' : 'hidden' %>">
                    <span>Coupon Discount</span>
                    <span class="text-emerald-600" id="coupon-discount">- ₹<%= totals.couponDiscount %></span>
                </div>

                <!-- Cash handling charge row -->
                <div id="cash-row" class="flex justify-between hidden">
                    <span>Cash Handling Fee</span>
                    <span class="text-zinc-800">+ ₹50</span>
                </div>

                <div class="flex justify-between">
                    <span>Shipping</span>
                    <span class="text-emerald-600 font-bold">FREE</span>
                </div>
                
                <div class="border-t border-zinc-100 pt-4 mt-4">
                    <div class="flex justify-between items-end">
                        <span class="text-zinc-800 font-bold text-base">Grand Total</span>
                        <span class="text-2xl font-extrabold text-zinc-800" id="grand-total" data-base="<%= totals.bill %>">₹<%= totals.bill %></span>
                    </div>
                </div>
            </div>

            <div class="flex items-center gap-2.5 justify-center text-xs text-zinc-400 font-semibold border-t border-zinc-50 pt-4">
                <i class="ri-shield-check-line text-lg text-emerald-500"></i> SSL Certified Encrypted Gateway
            </div>
        </div>

    </div>
</div>

<script>
    const upiFields = document.getElementById('upi-fields');
    const cardFields = document.getElementById('card-fields');
    const cashFields = document.getElementById('cash-fields');

    const inputUpi = document.getElementById('input-upiId');
    const inputCardholder = document.getElementById('input-cardholder');
    const inputCardnumber = document.getElementById('input-cardnumber');
    const inputExpiry = document.getElementById('input-expiry');
    const inputCvv = document.getElementById('input-cvv');

    const cashRow = document.getElementById('cash-row');
    const grandTotal = document.getElementById('grand-total');

    // Credit Card Mockup sync
    const cardMockup = document.getElementById('credit-card-mockup');
    const mockHolder = document.getElementById('mock-holder');
    const mockNumber = document.getElementById('mock-number');
    const mockExpiry = document.getElementById('mock-expiry');
    const mockCvv = document.getElementById('mock-cvv');

    if (inputCardholder) {
        inputCardholder.addEventListener('input', (e) => {
            mockHolder.textContent = e.target.value.toUpperCase() || 'FULL NAME';
        });
    }

    if (inputCardnumber) {
        inputCardnumber.addEventListener('input', (e) => {
            let value = e.target.value.replace(/\s+/g, '').replace(/[^0-9]/gi, '');
            let formatted = '';
            for (let i = 0; i < value.length; i++) {
                if (i > 0 && i % 4 === 0) formatted += ' ';
                formatted += value[i];
            }
            mockNumber.textContent = formatted || '•••• •••• •••• ••••';
        });
    }

    if (inputExpiry) {
        inputExpiry.addEventListener('input', (e) => {
            mockExpiry.textContent = e.target.value || 'MM/YY';
        });
    }

    if (inputCvv) {
        inputCvv.addEventListener('input', (e) => {
            mockCvv.textContent = '•'.repeat(e.target.value.length) || '•••';
        });
        inputCvv.addEventListener('focus', () => {
            cardMockup.classList.add('flip-active');
        });
        inputCvv.addEventListener('blur', () => {
            cardMockup.classList.remove('flip-active');
        });
    }

    function selectPayment(method) {
        // Toggle selected border styling
        document.querySelectorAll('.select-card').forEach(card => {
            card.classList.remove('border-blue-600', 'bg-blue-50/20');
            card.classList.add('border-zinc-100');
        });
        const activeCard = document.getElementById('card-' + method);
        activeCard.classList.remove('border-zinc-100');
        activeCard.classList.add('border-blue-600', 'bg-blue-50/20');

        // Toggle Fields visibility and validation
        if (method === 'UPI') {
            upiFields.classList.remove('hidden');
            cardFields.classList.add('hidden');
            cashFields.classList.add('hidden');

            inputUpi.required = true;
            inputCardholder.required = false;
            inputCardnumber.required = false;
            inputExpiry.required = false;
            inputCvv.required = false;

            cashRow.classList.add('hidden');
            updateTotal(0);
        } else if (method === 'Card') {
            upiFields.classList.add('hidden');
            cardFields.classList.remove('hidden');
            cashFields.classList.add('hidden');

            inputUpi.required = false;
            inputCardholder.required = true;
            inputCardnumber.required = true;
            inputExpiry.required = true;
            inputCvv.required = true;

            cashRow.classList.add('hidden');
            updateTotal(0);
        } else if (method === 'Cash') {
            upiFields.classList.add('hidden');
            cardFields.classList.add('hidden');
            cashFields.classList.remove('hidden');

            inputUpi.required = false;
            inputCardholder.required = false;
            inputCardnumber.required = false;
            inputExpiry.required = false;
            inputCvv.required = false;

            cashRow.classList.remove('hidden');
            updateTotal(50);
        }
    }

    function updateTotal(extraFee) {
        const baseTotal = parseInt(grandTotal.getAttribute('data-base')) || 0;
        const newTotal = baseTotal + extraFee;
        grandTotal.textContent = '₹' + newTotal;
    }

    // Run once on load to ensure right initial state
    selectPayment('UPI');
</script>

